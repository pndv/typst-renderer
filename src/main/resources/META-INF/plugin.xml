<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.pndv.typstrenderer</id>
    <name>Typst</name>
    <vendor>pndv</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lsp</depends>

    <resource-bundle>messages.TypstBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Typst file type -->
        <fileType
                name="Typst"
                implementationClass="com.github.pndv.typstrenderer.language.TypstFileType"
                fieldName="INSTANCE"
                language="Typst"
                extensions="typ"/>

        <!-- LSP support via tinymist -->
        <platform.lsp.serverSupportProvider
                implementation="com.github.pndv.typstrenderer.lsp.TinymistLspServerSupportProvider"/>

        <!-- Tinymist manager and downloader -->
        <applicationService
                serviceImplementation="com.github.pndv.typstrenderer.lsp.TinymistManager"/>
        <applicationService
                serviceImplementation="com.github.pndv.typstrenderer.lsp.TinymistDownloadService"/>

        <!-- Settings -->
        <applicationService
                serviceImplementation="com.github.pndv.typstrenderer.settings.TypstSettingsState"/>
        <applicationConfigurable
                parentId="tools"
                instance="com.github.pndv.typstrenderer.settings.TypstSettingsConfigurable"
                id="com.github.pndv.typstrenderer.settings.TypstSettingsConfigurable"
                displayName="Typst"/>

        <!-- Tool window for compilation output -->
        <toolWindow
                id="Typst Output"
                anchor="bottom"
                factoryClass="com.github.pndv.typstrenderer.toolWindow.TypstOutputToolWindowFactory"
                icon="AllIcons.Toolwindows.ToolWindowMessages"/>

        <!-- Split editor with live PDF preview -->
        <fileEditorProvider
                implementation="com.github.pndv.typstrenderer.editor.TypstSplitEditorProvider"/>

        <!-- Notifications -->
        <notificationGroup id="Typst" displayType="BALLOON"/>
    </extensions>

    <actions>
        <action id="Typst.Compile"
                class="com.github.pndv.typstrenderer.actions.TypstCompileAction"
                text="Compile Typst File"
                description="Compile the current Typst file to PDF"
                icon="AllIcons.Actions.Execute">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift T"/>
        </action>

        <action id="Typst.Watch"
                class="com.github.pndv.typstrenderer.actions.TypstWatchAction"
                text="Watch Typst File"
                description="Watch the current Typst file for changes and auto-compile"
                icon="AllIcons.Actions.Restart">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
